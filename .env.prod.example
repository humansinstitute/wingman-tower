TOWER_PORT=3100
TOWER_HOST_PORT=3100
SUPERBASED_DIRECT_HTTPS_URL=https://sb4.otherstuff.studio

# Admin browser identity allowed to use /table-viewer and /api/v4/admin/*
ADMIN_NPUB=npub1jss47s4fvv6usl7tn6yp5zamv2u60923ncgfea0e6thkza5p7c3q0afmzy

# Service identity. Keep this stable in production.
SUPERBASED_SERVICE_NSEC=nsec1replace-me

# Optional derived identity values. If omitted, Tower derives them from SUPERBASED_SERVICE_NSEC.
# SUPERBASED_SERVICE_PUBKEY_HEX=
# SUPERBASED_SERVICE_NPUB=

# MinIO published ports for the bundled S3-compatible storage service.
MINIO_API_HOST_PORT=9000
MINIO_CONSOLE_HOST_PORT=9001

# S3 / MinIO used by Tower.
# Default assumes the bundled MinIO service in docker-compose.prod.yml.
# Override these if you intentionally point Tower at an external S3-compatible service.
STORAGE_S3_ENDPOINT=http://minio:9000
STORAGE_S3_ENDPOINT_PUBLIC=http://127.0.0.1:9000
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=superbased
STORAGE_S3_SECRET_KEY=superbased-secret
STORAGE_S3_BUCKET=superbased-storage
STORAGE_S3_FORCE_PATH_STYLE=true
STORAGE_PRESIGN_UPLOAD_TTL_SECONDS=900
STORAGE_PRESIGN_DOWNLOAD_TTL_SECONDS=900

# Postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=coworker_v4
DB_USER=postgres
DB_PASSWORD=change-me
DB_MAX_CONNECTIONS=10

# Optional startup tuning
DB_WAIT_MAX_ATTEMPTS=40
